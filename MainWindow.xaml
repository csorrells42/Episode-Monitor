<Window x:Class="EpisodeMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Episode Monitor"
        MinHeight="720"
        MinWidth="1100"
        Height="820"
        Width="1280"
        Background="#080d12"
        Foreground="#f5f8fb"
        Loaded="WindowLoaded"
        Closing="WindowClosing">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#101820" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#0c1218" />
        <SolidColorBrush x:Key="BorderBrush" Color="#243545" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#f5f8fb" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#142130" />
            <Setter Property="Foreground" Value="#f5f8fb" />
            <Setter Property="BorderBrush" Value="#37506a" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinHeight" Value="34" />
        </Style>

        <Style x:Key="NarcolepsyActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="180" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>

        <Style x:Key="StartStopButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="180" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="ToggleButton">
            <Setter Property="Background" Value="#142130" />
            <Setter Property="Foreground" Value="#f5f8fb" />
            <Setter Property="BorderBrush" Value="#37506a" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinHeight" Value="34" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#0f1720" />
            <Setter Property="Foreground" Value="#f5f8fb" />
            <Setter Property="BorderBrush" Value="#37506a" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="1"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <Grid>
                                    <ContentPresenter Margin="9,0,32,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      RecognizesAccessKey="True"
                                                      TextElement.Foreground="{TemplateBinding Foreground}" />
                                    <Path HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Margin="0,0,10,0"
                                          Fill="#f5f8fb"
                                          Data="M 0 0 L 4 4 L 8 0 Z" />
                                </Grid>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border Background="#0f1720"
                                        BorderBrush="#d7e7f3"
                                        BorderThickness="1"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="320" CanContentScroll="True">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="#6b92b6" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#0f1720" />
            <Setter Property="Foreground" Value="#f5f8fb" />
            <Setter Property="Padding" Value="8,6" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#243f58" />
                    <Setter Property="Foreground" Value="#ffffff" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1d3348" />
                    <Setter Property="Foreground" Value="#ffffff" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#f5f8fb" />
            <Setter Property="Margin" Value="0,7,0,0" />
        </Style>

        <Style TargetType="Expander">
            <Setter Property="Foreground" Value="#f5f8fb" />
            <Setter Property="Background" Value="#101820" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0c1218" />
            <Setter Property="Foreground" Value="#f5f8fb" />
            <Setter Property="BorderBrush" Value="#243545" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowBackground" Value="#0c1218" />
            <Setter Property="AlternatingRowBackground" Value="#101820" />
            <Setter Property="HorizontalGridLinesBrush" Value="#1d2c38" />
            <Setter Property="VerticalGridLinesBrush" Value="#1d2c38" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#182532" />
            <Setter Property="Foreground" Value="#f5f8fb" />
            <Setter Property="BorderBrush" Value="#2b4054" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="260" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Camera" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold" />
                <ComboBox x:Name="CameraComboBox" Grid.Column="1" SelectionChanged="CameraSelectionChanged" />
                <TextBlock Grid.Column="2" Text="Mode" VerticalAlignment="Center" Margin="14,0,8,0" FontWeight="SemiBold" />
                <ComboBox x:Name="CameraModeComboBox" Grid.Column="3" SelectionChanged="CameraModeSelectionChanged" />
                <ToggleButton x:Name="CameraToggle" Grid.Column="4" Margin="14,0,0,0" Content="Camera Off" Checked="CameraToggleChanged" Unchecked="CameraToggleChanged" />
                <Button Grid.Column="5" Margin="8,0,0,0" Content="Refresh" Click="RefreshCamerasClicked" />
                <TextBlock x:Name="TopStatusText" Grid.Column="6" Text="Ready." VerticalAlignment="Center" Margin="14,0,0,0" Foreground="#b9d7ef" />
                <Button Grid.Column="7" Content="Close" Click="CloseClicked" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,14,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="390" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="230" />
            </Grid.RowDefinitions>

            <Border Grid.Column="0" Grid.Row="0" Background="#05080c" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid x:Name="PreviewHost" SizeChanged="PreviewHostSizeChanged">
                    <Grid x:Name="DirectX12PreviewLayer" Visibility="Collapsed" ClipToBounds="True" />
                    <Image x:Name="PreviewImage" Stretch="Uniform" Visibility="Collapsed" />
                    <Canvas x:Name="LiveWireframeCanvas" Visibility="Collapsed" ClipToBounds="True" Background="#05080c" />
                    <Canvas x:Name="FaceCueGuideCanvas" IsHitTestVisible="False" />
                    <StackPanel x:Name="PreviewPlaceholder" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Episode Monitor" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock x:Name="PreviewStateText" Text="Camera disabled" Margin="0,10,0,0" Foreground="#b9d7ef" HorizontalAlignment="Center" />
                    </StackPanel>
                    <Border x:Name="TrackingOverlay" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="14" Background="#d8080d12" BorderBrush="#37506a" BorderThickness="1" Padding="10" MinWidth="360" MaxWidth="860">
                        <StackPanel>
                            <TextBlock x:Name="OverlayStateText" Text="Tracking idle" FontWeight="Bold" TextWrapping="Wrap" />
                            <TextBlock x:Name="OverlayMetricText" Text="Motion -- | Threshold --" Foreground="#b9d7ef" TextWrapping="Wrap" Margin="0,4,0,0" />
                            <TextBlock x:Name="OverlayTriggerText" Text="Enable episode watch to arm tracking." Foreground="#b9d7ef" TextWrapping="Wrap" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Grid.Row="0" Margin="14,0,0,0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,0,18,0">
                        <Border Background="#0c1218" BorderBrush="#243545" BorderThickness="1" Padding="12" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Narcolepsy Tracking" FontSize="20" FontWeight="Bold" />
                                <TextBlock Text="Logs observable sustained low-motion events for review. This does not diagnose a medical condition." Foreground="#b9d7ef" TextWrapping="Wrap" Margin="0,8,0,8" />

                                <Button x:Name="SleepEventWatchButton" Style="{StaticResource StartStopButtonStyle}" Content="Start Sleep Event Watch" ToolTip="Starts or stops automatic event watching from low motion, eye cues, mouth cues, and trends." HorizontalAlignment="Left" Margin="0,8,0,8" Click="SleepEventWatchClicked" />
                                <CheckBox x:Name="SnapshotCheckBox" Content="Save snapshots at episode start and end" ToolTip="Adds still images to each event folder for quick review." IsChecked="True" />
                                <CheckBox x:Name="EventVideoCheckBox" Content="Save webcam video for events" ToolTip="Writes an annotated webcam MP4 into each event folder when enabled." IsChecked="True" />

                                <Separator Margin="0,18,0,14" Background="#243545" />

                                <TextBlock Text="Actions" FontSize="16" FontWeight="Bold" />
                                <WrapPanel Margin="0,10,0,0">
                                    <Button x:Name="CalibrateAlertBaselineButton" Style="{StaticResource NarcolepsyActionButtonStyle}" Content="Calibrate Alert Baseline" ToolTip="Use only when you are awake, alert, and not experiencing symptoms. Learns the reference eye, mouth, and jaw measurements." Click="CalibrateAlertBaselineClicked" />
                                    <Button x:Name="SymptomCaptureButton" Style="{StaticResource NarcolepsyActionButtonStyle}" Content="Capture Symptoms" ToolTip="Marks symptoms, protects the alert baseline, and starts or stops an event recording." Click="SymptomCaptureClicked" />
                                    <Button Style="{StaticResource NarcolepsyActionButtonStyle}" Content="Export Event List" Click="ExportClicked" />
                                    <Button Style="{StaticResource NarcolepsyActionButtonStyle}" Content="View Event Log" Click="OpenEventLogClicked" />
                                </WrapPanel>
                                <TextBlock x:Name="CalibrationGuardText" Text="Alert baseline calibration is available when you are awake, alert, and symptom-free." Foreground="#b9d7ef" TextWrapping="Wrap" Margin="0,8,0,0" />

                                <Separator Margin="0,18,0,14" Background="#243545" />

                                <Expander Header="Event Triggers" IsExpanded="False">
                                    <StackPanel Margin="0,10,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Low-motion threshold" FontWeight="SemiBold" />
                                            <TextBlock x:Name="ThresholdValueText" Grid.Column="1" Text="1.5%" Foreground="#b9d7ef" />
                                        </Grid>
                                        <Slider x:Name="ThresholdSlider" Minimum="0.2" Maximum="8" Value="1.5" TickPlacement="BottomRight" Ticks="1.5" ValueChanged="SettingChanged" />

                                        <Grid Margin="0,18,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Stillness time" FontWeight="SemiBold" />
                                            <TextBlock x:Name="StillnessValueText" Grid.Column="1" Text="120s" Foreground="#b9d7ef" />
                                        </Grid>
                                        <Slider x:Name="StillnessSlider" Minimum="15" Maximum="900" Value="120" TickPlacement="BottomRight" Ticks="120" ValueChanged="SettingChanged" />

                                        <Grid Margin="0,18,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Eye cue sensitivity" FontWeight="SemiBold" />
                                            <TextBlock x:Name="EyeCueValueText" Grid.Column="1" Text="35%" Foreground="#b9d7ef" />
                                        </Grid>
                                        <Slider x:Name="EyeCueSlider" Minimum="15" Maximum="80" Value="35" TickPlacement="BottomRight" Ticks="35" ValueChanged="SettingChanged" />

                                        <Grid Margin="0,18,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Jaw cue sensitivity" FontWeight="SemiBold" />
                                            <TextBlock x:Name="JawCueValueText" Grid.Column="1" Text="35%" Foreground="#b9d7ef" />
                                        </Grid>
                                        <Slider x:Name="JawCueSlider" Minimum="15" Maximum="120" Value="35" TickPlacement="BottomRight" Ticks="35" ValueChanged="SettingChanged" />

                                        <Grid Margin="0,18,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Face cue time" FontWeight="SemiBold" />
                                            <TextBlock x:Name="FaceCueTimeValueText" Grid.Column="1" Text="3s" Foreground="#b9d7ef" />
                                        </Grid>
                                        <Slider x:Name="FaceCueTimeSlider" Minimum="1" Maximum="20" Value="3" TickPlacement="BottomRight" Ticks="3" ValueChanged="SettingChanged" />

                                        <Grid Margin="0,18,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Eye-led AI cue score" FontWeight="SemiBold" />
                                            <TextBlock x:Name="CompositeCueValueText" Grid.Column="1" Text="55%" Foreground="#b9d7ef" />
                                        </Grid>
                                        <Slider x:Name="CompositeCueSlider" Minimum="25" Maximum="90" Value="55" TickPlacement="BottomRight" Ticks="55" ValueChanged="SettingChanged" />
                                    </StackPanel>
                                </Expander>

                                <Separator Margin="0,18,0,14" Background="#243545" />

                                <Expander Header="Face Tracking Field" IsExpanded="False">
                                    <StackPanel Margin="0,10,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Face field horizontal" FontWeight="SemiBold" />
                                            <TextBlock x:Name="FaceFieldXValueText" Grid.Column="1" Text="50%" Foreground="#b9d7ef" />
                                        </Grid>
                                        <Slider x:Name="FaceFieldXSlider" Minimum="20" Maximum="80" Value="50" TickPlacement="BottomRight" Ticks="50" ValueChanged="SettingChanged" />

                                        <Grid Margin="0,18,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Face field vertical" FontWeight="SemiBold" />
                                            <TextBlock x:Name="FaceFieldYValueText" Grid.Column="1" Text="48%" Foreground="#b9d7ef" />
                                        </Grid>
                                        <Slider x:Name="FaceFieldYSlider" Minimum="20" Maximum="80" Value="48" TickPlacement="BottomRight" Ticks="48" ValueChanged="SettingChanged" />

                                        <Grid Margin="0,18,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Face field size" FontWeight="SemiBold" />
                                            <TextBlock x:Name="FaceFieldSizeValueText" Grid.Column="1" Text="60%" Foreground="#b9d7ef" />
                                        </Grid>
                                        <Slider x:Name="FaceFieldSizeSlider" Minimum="25" Maximum="90" Value="60" TickPlacement="BottomRight" Ticks="60" ValueChanged="SettingChanged" />
                                        <CheckBox x:Name="FaceAutoFollowCheckBox" Content="Auto-follow face field" IsChecked="True" Checked="FaceCueChanged" Unchecked="FaceCueChanged" />
                                    </StackPanel>
                                </Expander>

                                <TextBlock x:Name="MonitorStatusText" Text="Episode monitor idle." TextWrapping="Wrap" Margin="0,8,0,0" Foreground="#b9d7ef" />

                                <Separator Margin="0,18,0,14" Background="#243545" />

                                <TextBlock Text="Output" FontSize="16" FontWeight="Bold" />
                                <TextBlock x:Name="OutputFolderText" TextWrapping="Wrap" Foreground="#b9d7ef" Margin="0,8,0,0" />
                                <Button Content="Choose Folder" HorizontalAlignment="Left" Margin="0,8,0,0" Click="BrowseOutputClicked" />
                            </StackPanel>
                        </Border>

                        <Border Background="#0c1218" BorderBrush="#243545" BorderThickness="1" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Avatar Building" FontSize="20" FontWeight="Bold" />
                                <TextBlock Text="Collects measurement-only face movement data for future avatar and 3D systems." Foreground="#b9d7ef" TextWrapping="Wrap" Margin="0,8,0,8" />

                                <CheckBox x:Name="PersonalModelSubjectCheckBox" Content="This is Chris - collect my face model" ToolTip="Allows measurement-only learning for Chris; leave unchecked when someone else is at the camera." Checked="PersonalModelSubjectChanged" Unchecked="PersonalModelSubjectChanged" />

                                <Border Background="#081018" BorderBrush="#243545" BorderThickness="1" Padding="10" Margin="0,10,0,0">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border x:Name="AvatarLearningIndicator" Width="11" Height="11" CornerRadius="6" Background="#59616b" Margin="0,0,8,0" VerticalAlignment="Center" />
                                            <TextBlock x:Name="AvatarLearningStateText" Grid.Column="1" Text="Avatar learning stopped" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" />
                                            <Button x:Name="AvatarLearningToggleButton" Grid.Column="2" Style="{StaticResource StartStopButtonStyle}" Content="Start Avatar Learning" ToolTip="Starts or stops measurement-only learning for the Avatar System. Event recording is separate." Padding="10,6" Margin="8,0,0,0" Click="AvatarLearningToggleClicked" />
                                        </Grid>
                                        <TextBlock x:Name="AvatarLearningStatusText" Text="Not learning: confirm Chris, then start avatar learning when you are symptom-free." Foreground="#b9d7ef" TextWrapping="Wrap" Margin="0,8,0,0" />
                                        <TextBlock x:Name="AvatarTrackingSanityText" Text="Tracking sanity: waiting for enough accepted measurements." Foreground="#b9d7ef" TextWrapping="Wrap" Margin="0,6,0,0" />
                                        <Border Background="#0b141c" BorderBrush="#243545" BorderThickness="1" Padding="10" Margin="0,10,0,0">
                                            <StackPanel>
                                                <TextBlock x:Name="AvatarEasyModeTitleText" Text="Easy Avatar Mode" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                <TextBlock x:Name="AvatarEasyModeDetailText" Text="Confirm Chris, start the camera, then use easy mode for the next recommended avatar capture." Foreground="#b9d7ef" TextWrapping="Wrap" Margin="0,6,0,0" />
                                                <Button x:Name="AvatarEasyModeButton" Style="{StaticResource StartStopButtonStyle}" Content="Easy Avatar Mode" ToolTip="Starts guided measurement-only avatar learning and follows the next capture-plan recommendation." HorizontalAlignment="Left" Padding="10,6" Margin="0,8,0,0" Click="AvatarEasyModeClicked" />
                                            </StackPanel>
                                        </Border>
                                        <UniformGrid Columns="2" Margin="0,10,0,0">
                                            <Button Content="Open Avatar System" ToolTip="Opens one combined page for face preview, learning data, collection audit, avatar package, and next capture plan." Margin="0,0,6,0" Click="OpenAvatarSystemClicked" />
                                            <Button Content="Open Last 10 Good Features" ToolTip="Opens the rolling dense landmark mesh viewer for the latest ten good feature locks." Margin="6,0,0,0" Click="OpenLastGoodFeaturesClicked" />
                                            <Button x:Name="RebuildAvatarDataButton" Content="Rebuild Avatar Data" ToolTip="Archives the current Avatar measurements and starts a fresh measurement-only model." Margin="0,8,6,0" Click="RebuildAvatarDataClicked" />
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>

                                <Separator Margin="0,18,0,14" Background="#243545" />

                                <TextBlock Text="Camera and Model Quality" FontSize="16" FontWeight="Bold" />

                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Tracking fidelity" FontWeight="SemiBold" />
                                    <TextBlock x:Name="TrackingFidelityValueText" Grid.Column="1" Text="HD" Foreground="#b9d7ef" />
                                </Grid>
                                <ComboBox x:Name="TrackingFidelityComboBox" SelectionChanged="TrackingFidelitySelectionChanged" />
                                <TextBlock x:Name="TrackingFidelityStatusText" Text="Tracking frames: 1920px max at 10 fps." Foreground="#b9d7ef" TextWrapping="Wrap" Margin="0,6,0,0" />
                                <CheckBox x:Name="DirectX12PreviewCheckBox" Content="DX12 preview viewport" IsChecked="True" Checked="DirectX12PreviewChanged" Unchecked="DirectX12PreviewChanged" />
                                <ToggleButton x:Name="LiveWireframePreviewToggle" Content="Show Live Wireframe" ToolTip="Hides the webcam preview and shows the latest accepted dense wireframe sample while camera analysis keeps running." HorizontalAlignment="Left" Margin="0,8,0,0" Checked="LiveWireframePreviewChanged" Unchecked="LiveWireframePreviewChanged" />
                                <CheckBox x:Name="LiveWireframeHeadLockCheckBox" Content="Head-lock live wireframe" IsChecked="True" ToolTip="Draws the live dense wireframe in a head-attached eye-line/chin coordinate frame so feature sliding is easier to spot." Checked="LiveWireframeHeadLockChanged" Unchecked="LiveWireframeHeadLockChanged" />

                                <Separator Margin="0,18,0,14" Background="#243545" />

                                <Expander Header="Camera Controls" IsExpanded="False">
                                    <StackPanel Margin="0,8,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Camera Controls" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                                            <Button Grid.Column="1" Content="Refresh" Padding="10,6" MinHeight="30" Click="RefreshCameraControlsClicked" />
                                        </Grid>
                                        <TextBlock x:Name="CameraControlsStatusText" Text="Choose a camera to load controls." Foreground="#b9d7ef" TextWrapping="Wrap" Margin="0,8,0,0" />
                                        <StackPanel x:Name="CameraControlsPanel" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Margin="0,14,0,0" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <DataGrid x:Name="EventGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" PreviewMouseRightButtonDown="EventGridRightClick">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Delete Event" Click="DeleteSelectedEventClicked" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Started" Binding="{Binding StartLabel}" Width="150" />
                        <DataGridTextColumn Header="Ended" Binding="{Binding EndLabel}" Width="150" />
                        <DataGridTextColumn Header="Duration" Binding="{Binding Duration}" Width="95" />
                        <DataGridTextColumn Header="Event" Binding="{Binding Event}" Width="180" />
                        <DataGridTextColumn Header="Avg Motion" Binding="{Binding AvgMotion}" Width="110" />
                        <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="240" />
                        <DataGridTextColumn Header="Files" Binding="{Binding File}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <TextBlock x:Name="FooterText" Grid.Row="2" Text="Ready." Foreground="#b9d7ef" />
    </Grid>
</Window>
